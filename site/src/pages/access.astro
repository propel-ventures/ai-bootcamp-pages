---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Request Access" description="Complete a short form to access the AI Bootcamp content.">
  <section class="max-w-3xl mx-auto px-4 md:px-8 py-12">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 md:p-8">
      <span class="inline-block text-sm font-semibold text-propel-cyan bg-propel-cyan/20 px-3 py-1 rounded-full">Access Form</span>
      <h1 class="text-3xl md:text-4xl font-bold text-propel-navy mt-4 mb-3">AI Bootcamp Access</h1>
      <p class="text-gray-600 mb-8">
        Fill out your details to unlock the bootcamp links.
      </p>

      <form id="access-form" class="space-y-4">
        <div>
          <label for="name" class="block text-sm font-medium text-propel-navy mb-1">Full name</label>
          <input id="name" name="name" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-propel-cyan" />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-propel-navy mb-1">Work email</label>
          <input id="email" name="email" type="email" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-propel-cyan" />
        </div>

        <div>
          <label for="team" class="block text-sm font-medium text-propel-navy mb-1">Team / role</label>
          <input id="team" name="team" required class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-propel-cyan" />
        </div>

        <button type="submit" class="btn-primary w-full md:w-auto">Get Bootcamp Links</button>
      </form>

      <div id="access-result" class="hidden mt-8 p-4 md:p-6 border border-propel-cyan/40 bg-propel-cyan/10 rounded-xl">
        <h2 class="text-xl font-semibold text-propel-navy mb-2">Access Granted</h2>
        <p class="text-gray-700 mb-4">Use the links below to enter the bootcamp.</p>
        <div class="flex flex-col md:flex-row gap-3">
          <a href={`${baseUrl}course-1/`} class="btn-secondary text-center">Week 1: Elements of AI Engineering</a>
          <a href={`${baseUrl}course-2/`} class="btn-secondary text-center">Week 2: AI Workflows & Engineering</a>
        </div>
      </div>

      <p class="text-xs text-gray-500 mt-6">
        Pilot behavior: this form is client-side only and stores data in your browser for demo purposes.
      </p>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('access-form');
    const result = document.getElementById('access-result');

    if (form && result) {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const payload = {
          name: data.get('name'),
          email: data.get('email'),
          team: data.get('team'),
          submittedAt: new Date().toISOString(),
        };

        localStorage.setItem('bootcamp-access-request', JSON.stringify(payload));
        result.classList.remove('hidden');
      });
    }
  </script>
</Layout>
