---
import { getCollection } from 'astro:content';
import CourseCard from '../components/CourseCard.astro';
import { courseCatalog } from '../data/courseCatalog';
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path = '') => `${baseUrl}${path}`.replace(/\/{2,}/g, '/');
const modules = await getCollection('modules');
const moduleCountByCourse = new Map<number, number>();

for (const module of modules) {
  moduleCountByCourse.set(module.data.course, (moduleCountByCourse.get(module.data.course) ?? 0) + 1);
}

const courses = courseCatalog.map((course) => ({
  ...course,
  href: withBase(`${course.slug}/`),
  moduleCount: moduleCountByCourse.get(course.courseNumber) ?? 0,
}));
---

<Layout title="Courses" description="Browse every AI Bootcamp course and jump into any module.">
  <section class="bg-propel-navy text-white py-16 md:py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <div class="absolute top-0 right-0 w-96 h-96 bg-propel-cyan rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-propel-blue rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-6xl mx-auto px-4 md:px-8 relative z-10">
      <span class="inline-block text-sm font-semibold text-propel-cyan bg-propel-cyan/20 px-3 py-1 rounded-full">Course Hub</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-4 mb-4">All AI Engineering Courses</h1>
      <p class="text-lg md:text-xl text-white/80 max-w-3xl leading-relaxed">
        Use this page as the single post-form destination. Every week and module lives here, so the Microsoft Form only needs one stable link.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 md:px-8 py-14 md:py-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-propel-blue">Curriculum</p>
        <h2 class="text-3xl md:text-4xl font-bold text-propel-navy mt-2">Choose a week and start learning</h2>
      </div>
      <a href={withBase('access/')} class="text-propel-blue font-semibold hover:text-propel-orange transition-colors">
        Need the form again?
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {courses.map((course) => (
        <CourseCard
          title={course.title}
          week={course.weekLabel}
          description={course.description}
          href={course.href}
          moduleCount={course.moduleCount}
        />
      ))}
    </div>
  </section>
</Layout>
